[gd_resource type="Resource" script_class="LootTable" load_steps=7 format=3]

[ext_resource type="Script" path="res://game/drops/loot_table.gd" id="1_loot_table"]
[ext_resource type="Script" path="res://game/drops/drop_entry.gd" id="2_drop_entry"]
[ext_resource type="Resource" path="res://game/weapons/wave_cannon.tres" id="3_wave_cannon"]

[sub_resource type="Resource" id="DropEntry_experience"]
script = ExtResource("2_drop_entry")
drop_type = &"experience"
chance = 1.0
min_amount = 25
max_amount = 25

[sub_resource type="Resource" id="DropEntry_money"]
script = ExtResource("2_drop_entry")
drop_type = &"money"
chance = 1.0
min_amount = 20
max_amount = 20

[sub_resource type="Resource" id="DropEntry_weapon"]
script = ExtResource("2_drop_entry")
drop_type = &"weapon"
chance = 1.0
min_amount = 1
max_amount = 1
weapon_data = ExtResource("3_wave_cannon")

[resource]
script = ExtResource("1_loot_table")
entries = Array[ExtResource("2_drop_entry")]([SubResource("DropEntry_experience"), SubResource("DropEntry_money"), SubResource("DropEntry_weapon")])
