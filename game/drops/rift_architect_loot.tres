[gd_resource type="Resource" script_class="LootTable" load_steps=7 format=3]

[ext_resource type="Script" path="res://game/drops/loot_table.gd" id="1_loot"]
[ext_resource type="Script" path="res://game/drops/drop_entry.gd" id="2_entry"]
[ext_resource type="Resource" path="res://game/weapons/rift_repeater.tres" id="3_weapon"]

[sub_resource type="Resource" id="DropEntry_xp"]
script = ExtResource("2_entry")
drop_type = &"experience"
chance = 1.0
min_amount = 30
max_amount = 30

[sub_resource type="Resource" id="DropEntry_money"]
script = ExtResource("2_entry")
drop_type = &"money"
chance = 1.0
min_amount = 24
max_amount = 24

[sub_resource type="Resource" id="DropEntry_weapon"]
script = ExtResource("2_entry")
drop_type = &"weapon"
chance = 1.0
min_amount = 1
max_amount = 1
weapon_data = ExtResource("3_weapon")

[resource]
script = ExtResource("1_loot")
entries = Array[ExtResource("2_entry")]([SubResource("DropEntry_xp"), SubResource("DropEntry_money"), SubResource("DropEntry_weapon")])
