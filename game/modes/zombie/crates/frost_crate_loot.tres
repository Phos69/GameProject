[gd_resource type="Resource" script_class="LootTable" load_steps=5 format=3]

[ext_resource type="Script" path="res://game/drops/loot_table.gd" id="1_loot"]
[ext_resource type="Script" path="res://game/drops/drop_entry.gd" id="2_entry"]

[sub_resource type="Resource" id="DropEntry_thermal"]
script = ExtResource("2_entry")
drop_type = &"health"
chance = 1.0
min_amount = 18
max_amount = 26
resource_tag = &"thermal_kit"

[sub_resource type="Resource" id="DropEntry_piercing"]
script = ExtResource("2_entry")
drop_type = &"ammo"
chance = 0.9
min_amount = 10
max_amount = 15
resource_tag = &"piercing_ammo"

[resource]
script = ExtResource("1_loot")
entries = Array[ExtResource("2_entry")]([SubResource("DropEntry_thermal"), SubResource("DropEntry_piercing")])
