[gd_resource type="Resource" script_class="LootTable" load_steps=5 format=3]

[ext_resource type="Script" path="res://game/drops/loot_table.gd" id="1_loot"]
[ext_resource type="Script" path="res://game/drops/drop_entry.gd" id="2_entry"]

[sub_resource type="Resource" id="DropEntry_antidote"]
script = ExtResource("2_entry")
drop_type = &"health"
chance = 1.0
min_amount = 22
max_amount = 30
resource_tag = &"antidote"

[sub_resource type="Resource" id="DropEntry_corrosive"]
script = ExtResource("2_entry")
drop_type = &"ammo"
chance = 0.9
min_amount = 8
max_amount = 13
resource_tag = &"corrosive_ammo"

[resource]
script = ExtResource("1_loot")
entries = Array[ExtResource("2_entry")]([SubResource("DropEntry_antidote"), SubResource("DropEntry_corrosive")])
